{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@lshay/opencontrol",
  "license": "MIT",
  "version": "0.1.4",
  "type": "module",
  "bin": {
    "opencontrol": "./bin/index.mjs"
  },
  "scripts": {
    "build": "./script/build.ts"
