    "ai": "^4.3.19",
    "hono": "^4.8.5",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@lshay/opencontrol-frontend": "workspace:*",
    "@standard-schema/spec": "1.0.0"
  }
}
